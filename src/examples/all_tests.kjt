func noFunc(u8 : u_int8, u16 : u_int16) -> char {
    u8 = 3;
    return 'c'; // This thing: ''
}
pure func pureNoFunc(u8 : u_int8, u16 : u_int16) -> char {
    return 'f';
}
proced procedures(u8 : u_int8) {
    u8 = 3;
}

